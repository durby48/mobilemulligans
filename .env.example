# Supabase — find these in your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (server-only). Never expose this to the client.
# Used as a fallback by the booking API route, and REQUIRED for the employee
# records vault (storage upload + RLS-bypassing trusted reads/writes).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Employee records vault (sensitive HR / payroll data) ---
# 32-byte key (base64) used to encrypt SSN + bank numbers at rest. REQUIRED for
# the records vault. Generate with:  openssl rand -base64 32
# Treat this like a root password: server-only, never commit, and rotating it
# requires re-encrypting existing rows.
EMPLOYEE_PII_KEY=your-base64-32-byte-key
# The SINGLE login allowed to read/write the records vault. Comma-separated is
# supported but keep it to one address. Defaults to the project owner if unset.
RECORDS_ADMIN_EMAIL=devonsd311@gmail.com

# Email notifications (Resend) — sends an email when a booking or waitlist form is submitted.
# Get an API key at https://resend.com (free tier available).
RESEND_API_KEY=your-resend-api-key
# Where notifications are delivered (defaults to the site email if omitted).
NOTIFICATION_TO=info@mobilemulligans.net
# Verified sender address in Resend (must be on a domain you've verified there).
NOTIFICATION_FROM=Mobile Mulligans <notifications@mobilemulligans.net>
