# Supabase — find these in your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: service role key (server-only). Never expose this to the client.
# Used as a fallback by the booking API route if you prefer not to rely on RLS inserts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email notifications (Resend) — sends an email when a booking or waitlist form is submitted.
# Get an API key at https://resend.com (free tier available).
RESEND_API_KEY=your-resend-api-key
# Where notifications are delivered (defaults to the site email if omitted).
NOTIFICATION_TO=info@mobilemulligans.net
# Verified sender address in Resend (must be on a domain you've verified there).
NOTIFICATION_FROM=Mobile Mulligans <notifications@mobilemulligans.net>
