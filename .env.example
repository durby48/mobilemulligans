# Supabase — find these in your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: service role key (server-only). Never expose this to the client.
# Used as a fallback by the booking API route if you prefer not to rely on RLS inserts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
